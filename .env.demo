# Agentic GenAI Security Accelerator — Safe Demo Mode
# ═══════════════════════════════════════════════════════════════════
#
# This is the recommended default for customer demos and evaluations.
# It enables the FULL agent workflow in dry-run mode:
#   Finding → Investigation → Plan → Queue → Approve → Dry-Run Execute → Audit
#
# NO AWS RESOURCES WILL BE CHANGED in this mode.
# All execution is simulated. Results are clearly labeled as dry-run.
#
# To enable live low-risk remediation, see .env.live-low-risk.example
# ═══════════════════════════════════════════════════════════════════

AWS_REGION=us-east-1
APP_MODE=connected
AWS_PROFILE=default

# Bedrock (enable for live AI chat)
BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# MCP Configuration
AWS_MCP_ENABLED=true
AWS_KNOWLEDGE_MCP_ENABLED=true
MCP_CONFIG_PATH=./mcp_config.json

# Optional AWS MCPs (read-only)
AWS_API_MCP_ENABLED=true
AWS_API_MCP_READ_ONLY=true
IAM_MCP_ENABLED=true
IAM_MCP_READ_ONLY=true
CLOUDTRAIL_MCP_ENABLED=true
SECURITYHUB_MCP_ENABLED=true

# Prowler
PROWLER_ENABLED=true
PROWLER_OUTPUT_DIR=./sample-data/prowler-output
AUTO_RUN_PROWLER_ON_START=false
AUTO_ENABLE_ACCOUNT_MCPS_ON_AWS_CONNECT=true

# S3 Report Storage
REPORT_STORAGE_MODE=s3
REPORT_BUCKET_NAME=
REPORT_BUCKET_PREFIX=agentic-security-posture
AUTO_CREATE_REPORT_BUCKET=false
S3_BUCKET_VERSIONING=true
S3_ENCRYPTION_ENABLED=true
S3_BLOCK_PUBLIC_ACCESS=true

# Prowler Scan Timeouts
PROWLER_QUICK_SCAN_TIMEOUT_SECONDS=1200
PROWLER_FULL_SCAN_TIMEOUT_SECONDS=3600
PROWLER_SMOKE_SCAN_TIMEOUT_SECONDS=300
PROWLER_ULTRA_MICRO_SCAN_TIMEOUT_SECONDS=120
PROWLER_DEFAULT_SCAN_MODE=ultra_micro

# ═══════════════════════════════════════════════════════════════════
# AGENT CAPABILITY FLAGS — Full Demo (Dry-Run)
# ═══════════════════════════════════════════════════════════════════

# Level 2-3: Live AWS read-only investigation
INVESTIGATION_TOOLS_ENABLED=true

# Level 4: Remediation planning (CLI, Terraform, CloudFormation, rollback)
REMEDIATION_PLANNING_ENABLED=true

# Level 5: Execution workflow (dry-run only in demo mode)
REMEDIATION_EXECUTION_ENABLED=true

# Risk controls — only low-risk allowed, medium/high blocked
ALLOW_MEDIUM_RISK_REMEDIATION=false
ALLOW_HIGH_RISK_REMEDIATION=false

# Safety — approval always required
REQUIRE_APPROVAL_FOR_ALL_REMEDIATION=true

# DRY-RUN MODE — No AWS changes will be made
# Set to false ONLY for live remediation against a test account
DRY_RUN_REMEDIATION=true

# IAM Roles (optional — leave empty for local dev with current credentials)
READ_ONLY_ROLE_ARN=
EXECUTION_ROLE_ARN=
