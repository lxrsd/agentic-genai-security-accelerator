# Agentic GenAI Security Accelerator — Findings Only Mode
# ═══════════════════════════════════════════════════════════════════
#
# Minimal mode: The assistant can only answer questions about imported
# Prowler findings, posture scores, and remediation recommendations.
#
# No live AWS investigation. No remediation planning. No execution.
# Use this if you only want the scoring dashboard without agent tools.
# ═══════════════════════════════════════════════════════════════════

AWS_REGION=us-east-1
APP_MODE=connected
AWS_PROFILE=default

BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

AWS_MCP_ENABLED=false
AWS_KNOWLEDGE_MCP_ENABLED=false
MCP_CONFIG_PATH=./mcp_config.json

PROWLER_ENABLED=true
AUTO_ENABLE_ACCOUNT_MCPS_ON_AWS_CONNECT=false

REPORT_STORAGE_MODE=local

# Agent Capability Flags — All disabled (findings only)
INVESTIGATION_TOOLS_ENABLED=false
REMEDIATION_PLANNING_ENABLED=false
REMEDIATION_EXECUTION_ENABLED=false
ALLOW_MEDIUM_RISK_REMEDIATION=false
ALLOW_HIGH_RISK_REMEDIATION=false
REQUIRE_APPROVAL_FOR_ALL_REMEDIATION=true
DRY_RUN_REMEDIATION=true

READ_ONLY_ROLE_ARN=
EXECUTION_ROLE_ARN=
