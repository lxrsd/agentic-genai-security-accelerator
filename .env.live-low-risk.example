# Agentic GenAI Security Accelerator — Live Low-Risk Remediation
# ═══════════════════════════════════════════════════════════════════
#
# WARNING: This mode CAN CHANGE AWS RESOURCES.
#
# Only use this against a safe test account or disposable test resources.
# Only low-risk allowlisted actions can run live:
#   - s3:PutPublicAccessBlock
#   - s3:PutEncryptionConfiguration
#   - kms:EnableKeyRotation
#   - guardduty:CreateDetector
#   - securityhub:BatchEnableStandards
#   - cloudtrail:CreateTrail
#   - cloudtrail:StartLogging
#
# Medium-risk and high-risk actions remain BLOCKED.
# Approval is ALWAYS required before execution.
# ═══════════════════════════════════════════════════════════════════

AWS_REGION=us-east-1
APP_MODE=connected
AWS_PROFILE=default

BEDROCK_ENABLED=true
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

AWS_MCP_ENABLED=true
AWS_KNOWLEDGE_MCP_ENABLED=true
MCP_CONFIG_PATH=./mcp_config.json
AWS_API_MCP_ENABLED=true
AWS_API_MCP_READ_ONLY=true
IAM_MCP_ENABLED=true
IAM_MCP_READ_ONLY=true
CLOUDTRAIL_MCP_ENABLED=true
SECURITYHUB_MCP_ENABLED=true

PROWLER_ENABLED=true
AUTO_ENABLE_ACCOUNT_MCPS_ON_AWS_CONNECT=true

REPORT_STORAGE_MODE=s3
REPORT_BUCKET_PREFIX=agentic-security-posture
S3_BLOCK_PUBLIC_ACCESS=true

# Agent Capability Flags
INVESTIGATION_TOOLS_ENABLED=true
REMEDIATION_PLANNING_ENABLED=true
REMEDIATION_EXECUTION_ENABLED=true
ALLOW_MEDIUM_RISK_REMEDIATION=false
ALLOW_HIGH_RISK_REMEDIATION=false
REQUIRE_APPROVAL_FOR_ALL_REMEDIATION=true

# LIVE EXECUTION — Set to false to enable real AWS changes
DRY_RUN_REMEDIATION=false

# REQUIRED: Execution role with least-privilege permissions
# Replace with your actual role ARN scoped to allowlisted actions only
READ_ONLY_ROLE_ARN=
EXECUTION_ROLE_ARN=arn:aws:iam::<account-id>:role/SecurityRemediationRole
