# Agentic GenAI Security Accelerator — Demo Mode
# Works without AWS credentials. Uses bundled sample Prowler findings.

AWS_REGION=us-east-1
APP_MODE=demo

# Bedrock (disabled for demo — no AWS credentials needed)
BEDROCK_ENABLED=false
BEDROCK_MODEL_ID=

# MCP Configuration
AWS_MCP_ENABLED=true
AWS_KNOWLEDGE_MCP_ENABLED=true
MCP_CONFIG_PATH=./mcp_config.json

# Optional AWS MCPs (disabled for demo)
AWS_API_MCP_ENABLED=false
AWS_API_MCP_READ_ONLY=true
IAM_MCP_ENABLED=false
IAM_MCP_READ_ONLY=true
CLOUDTRAIL_MCP_ENABLED=false
SECURITYHUB_MCP_ENABLED=false

# Prowler
PROWLER_ENABLED=false
PROWLER_OUTPUT_DIR=./sample-data/prowler-output
AUTO_RUN_PROWLER_ON_START=false
